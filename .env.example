# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ─── InfluxDB ───────────────────────────────────────
INFLUXDB_DB=net_monitor
INFLUXDB_ADMIN_USER=your_username
INFLUXDB_ADMIN_PASSWORD=your_secure_password

# ─── Grafana ────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=your_grafana_password

# ─── Cisco Devices (SSH via Netmiko) ────────────────
DEVICE_IP=192.168.x.x
SSH_USERNAME=admin
SSH_PASSWORD=your_cisco_password

# ─── Telegram Bot ───────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── SNMP ───────────────────────────────────────────
SNMP_COMMUNITY=your_community_string
SNMP_AGENT_IP=192.168.x.x

# ─── Alert Threshold ────────────────────────────────
CPU_ALERT_THRESHOLD=40
